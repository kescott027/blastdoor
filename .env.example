HOST=0.0.0.0
PORT=8080

# Internal Foundry URL (not public). Example: http://127.0.0.1:30000
FOUNDRY_TARGET=http://127.0.0.1:30000

# Password store backend: env, file, sqlite, or postgres
PASSWORD_STORE_MODE=env
PASSWORD_STORE_FILE=mock/password-store.json

# Config store backend: env, sqlite, or postgres
CONFIG_STORE_MODE=env

# Used when either *_STORE_MODE is sqlite
DATABASE_FILE=data/blastdoor.sqlite

# Used when either *_STORE_MODE is postgres
POSTGRES_URL=
POSTGRES_SSL=false

# Login credentials for the gateway (required when PASSWORD_STORE_MODE=env).
# When PASSWORD_STORE_MODE=sqlite|postgres, credentials are read from the users table.
AUTH_USERNAME=gm
AUTH_PASSWORD_HASH=

# Required: long random secret (at least 32 chars)
SESSION_SECRET=

# Security defaults
COOKIE_SECURE=true
TRUST_PROXY=1
SESSION_MAX_AGE_HOURS=12
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=8

# Enable MFA for strong access control
REQUIRE_TOTP=true
TOTP_SECRET=

# Set false only if your FOUNDRY_TARGET uses a self-signed cert
PROXY_TLS_VERIFY=true

# Optional comma-separated override when proxies rewrite host/proto
ALLOWED_ORIGINS=

# Allow literal Origin: null (off by default; useful for certain local browser contexts)
ALLOW_NULL_ORIGIN=false

# Cache /graphics assets in browser/CDN headers (set false for no-store)
GRAPHICS_CACHE_ENABLED=true

# Optional external blastdoor-api service. Leave blank for in-process API access.
BLASTDOOR_API_URL=
BLASTDOOR_API_TOKEN=
BLASTDOOR_API_TIMEOUT_MS=2500
BLASTDOOR_API_RETRY_MAX_ATTEMPTS=3
BLASTDOOR_API_RETRY_BASE_DELAY_MS=120
BLASTDOOR_API_RETRY_MAX_DELAY_MS=1200
BLASTDOOR_API_CIRCUIT_FAILURE_THRESHOLD=5
BLASTDOOR_API_CIRCUIT_RESET_MS=10000

# Integrated assistant runtime
ASSISTANT_ENABLED=true
ASSISTANT_URL=
ASSISTANT_TOKEN=
ASSISTANT_PROVIDER=heuristic
ASSISTANT_OLLAMA_URL=http://127.0.0.1:11434
ASSISTANT_OLLAMA_MODEL=llama3.1:8b
ASSISTANT_TIMEOUT_MS=6000
ASSISTANT_RETRY_MAX_ATTEMPTS=2
ASSISTANT_RAG_ENABLED=false
ASSISTANT_ALLOW_WEB_SEARCH=false
ASSISTANT_AUTO_LOCK_ON_THREAT=false
ASSISTANT_THREAT_SCORE_THRESHOLD=80
ASSISTANT_HOST=0.0.0.0
ASSISTANT_PORT=8060

# Email delivery for temporary codes and user->admin messages.
# EMAIL_PROVIDER: disabled | console | smtp
EMAIL_PROVIDER=disabled
EMAIL_FROM=
EMAIL_ADMIN_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_IGNORE_TLS=false
# Public URL for links in emails. If empty, the gateway host/port is used.
PUBLIC_BASE_URL=

# Optional hard lock toggle
BLAST_DOORS_CLOSED=false

# Install profile metadata generated by make install/configure
OBJECT_STORAGE_MODE=local
INSTALL_PROFILE=local
MANAGER_HOST=127.0.0.1
MANAGER_PORT=8090
BLASTDOOR_API_HOST=127.0.0.1
BLASTDOOR_API_PORT=8070

# Debug diagnostics (writes structured logs to console + file when true)
DEBUG_MODE=false
DEBUG_LOG_FILE=logs/blastdoor-debug.log
