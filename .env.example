HOST=0.0.0.0
PORT=8080

# Internal Foundry URL (not public). Example: http://127.0.0.1:30000
FOUNDRY_TARGET=http://127.0.0.1:30000

# Password store backend: env or file
PASSWORD_STORE_MODE=env
PASSWORD_STORE_FILE=mock/password-store.json

# Login credentials for the gateway (required when PASSWORD_STORE_MODE=env)
AUTH_USERNAME=gm
AUTH_PASSWORD_HASH=

# Required: long random secret (at least 32 chars)
SESSION_SECRET=

# Security defaults
COOKIE_SECURE=true
TRUST_PROXY=1
SESSION_MAX_AGE_HOURS=12
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=8

# Enable MFA for strong access control
REQUIRE_TOTP=true
TOTP_SECRET=

# Set false only if your FOUNDRY_TARGET uses a self-signed cert
PROXY_TLS_VERIFY=true

# Optional comma-separated override when proxies rewrite host/proto
ALLOWED_ORIGINS=

# Allow literal Origin: null (off by default; useful for certain local browser contexts)
ALLOW_NULL_ORIGIN=false

# Debug diagnostics (writes structured logs to console + file when true)
DEBUG_MODE=false
DEBUG_LOG_FILE=logs/blastdoor-debug.log
