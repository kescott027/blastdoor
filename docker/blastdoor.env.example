# Public DNS hostname for Caddy certificate + routing (must resolve to this host)
BLASTDOOR_DOMAIN=blastdoor.example.com
LETSENCRYPT_EMAIL=admin@example.com

# PostgreSQL bootstrap values (used by postgres container)
POSTGRES_DB=blastdoor
POSTGRES_USER=blastdoor
POSTGRES_PASSWORD=change-this-postgres-password

# Blastdoor runtime
HOST=0.0.0.0
PORT=8080

# Foundry endpoint reachable from inside the blastdoor container.
# With docker compose below, host.docker.internal works on macOS/Windows and Linux (via host-gateway mapping).
FOUNDRY_TARGET=http://host.docker.internal:30000

# Persist credentials and config in PostgreSQL
PASSWORD_STORE_MODE=postgres
CONFIG_STORE_MODE=postgres
POSTGRES_URL=postgres://blastdoor:change-this-postgres-password@postgres:5432/blastdoor
POSTGRES_SSL=false

# Optional env-mode auth fields (not used when PASSWORD_STORE_MODE=postgres)
AUTH_USERNAME=gm
AUTH_PASSWORD_HASH=

# Required strong secrets
SESSION_SECRET=replace-with-32-plus-char-random-secret
REQUIRE_TOTP=false
TOTP_SECRET=

# Required when running behind TLS-terminating Caddy
COOKIE_SECURE=true
TRUST_PROXY=1

# Security + diagnostics
SESSION_MAX_AGE_HOURS=12
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=8
PROXY_TLS_VERIFY=true
ALLOWED_ORIGINS=
ALLOW_NULL_ORIGIN=false
GRAPHICS_CACHE_ENABLED=true
BLASTDOOR_API_URL=
BLASTDOOR_API_TOKEN=
BLASTDOOR_API_TIMEOUT_MS=2500
BLASTDOOR_API_RETRY_MAX_ATTEMPTS=3
BLASTDOOR_API_RETRY_BASE_DELAY_MS=120
BLASTDOOR_API_RETRY_MAX_DELAY_MS=1200
BLASTDOOR_API_CIRCUIT_FAILURE_THRESHOLD=5
BLASTDOOR_API_CIRCUIT_RESET_MS=10000
ASSISTANT_ENABLED=true
ASSISTANT_URL=http://blastdoor-assistant:8060
ASSISTANT_TOKEN=
ASSISTANT_PROVIDER=heuristic
ASSISTANT_OLLAMA_URL=http://host.docker.internal:11434
ASSISTANT_OLLAMA_MODEL=llama3.1:8b
ASSISTANT_TIMEOUT_MS=6000
ASSISTANT_RETRY_MAX_ATTEMPTS=2
ASSISTANT_RAG_ENABLED=false
ASSISTANT_ALLOW_WEB_SEARCH=false
ASSISTANT_AUTO_LOCK_ON_THREAT=false
ASSISTANT_THREAT_SCORE_THRESHOLD=80
ASSISTANT_HOST=0.0.0.0
ASSISTANT_PORT=8060
OBJECT_STORAGE_MODE=local
INSTALL_PROFILE=container
BLASTDOOR_API_HOST=0.0.0.0
BLASTDOOR_API_PORT=8070
DEBUG_MODE=false
DEBUG_LOG_FILE=logs/blastdoor-debug.log

# Optional hard lock toggle
BLAST_DOORS_CLOSED=false
